{
    "name": "motion-graphics-agent",
    "module": "index.ts",
    "type": "module",
    "private": true,
    "workspaces": [
        "web",
        "mastra"
    ],
    "scripts": {
        "dev": "concurrently \"bun run dev:mastra\" \"bun run dev:web\"",
        "dev:web": "cd web && bun --env-file=../.env run dev",
        "dev:mastra": "git checkout HEAD -- mastra/.workspace && cd mastra && bun --bun --env-file=../.env run dev"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "concurrently": "^9.2.1"
    },
    "peerDependencies": {
        "typescript": "^5"
    }
}
