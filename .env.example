# Copy to .env and fill in. Do not commit .env.

# --------------------------------------------------------------------
# Azure OpenAI — via @ai-sdk/azure
# --------------------------------------------------------------------
# Effective Azure resource URL:
#   https://<RESOURCE>.openai.azure.com
# Use api-version=preview (or latest). Date-based versions (e.g. 2025-01-01-preview)
# only work against the legacy /openai/deployments/<DEP>/... URL and will 400 here.
AZURE_RESOURCE_NAME=eno1-resource
AZURE_API_KEY=
AZURE_API_VERSION=preview
AZURE_CHAT_DEPLOYMENT=gpt-4o
AZURE_CODING_DEPLOYMENT=gpt-5.3-codex
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# --------------------------------------------------------------------
# Sandbox wiring (used across phases)
# --------------------------------------------------------------------
SANDBOX_MCP_URL=http://localhost:4311/mcp
# Optional override. Defaults to <repo>/sandbox/.workspace.
# WORKSPACE_PATH=C:\absolute\path\to\workspace
SANDBOX_HTTP_PORT=4311
