# Copy to .env and fill in. Do not commit .env.

# --------------------------------------------------------------------
# Azure OpenAI — /openai/v1 surface (OpenAI-compatible)
# --------------------------------------------------------------------
# Effective request URL for chat + embeddings:
#   https://<RESOURCE>.openai.azure.com/openai/v1/{chat/completions,embeddings}?api-version=<VERSION>
# Use api-version=preview (or latest). Date-based versions (e.g. 2025-01-01-preview)
# only work against the legacy /openai/deployments/<DEP>/... URL and will 400 here.
AZURE_RESOURCE_NAME=eno1-resource
AZURE_API_KEY=
AZURE_API_VERSION=preview
AZURE_CHAT_DEPLOYMENT=gpt-5.4-1
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# --------------------------------------------------------------------
# Persistence + sandbox wiring (used across phases)
# --------------------------------------------------------------------
LIBSQL_URL=file:./mastra/data/motion-graphics-agent.db
SANDBOX_MCP_URL=http://localhost:4311/mcp
SANDBOX_WORKSPACE_DIR=./sandbox/.workspace
SANDBOX_PORT=3001
