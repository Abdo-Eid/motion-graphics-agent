# dependencies (bun install)
node_modules/

# secrets — block every .env variant; keep .env.example tracked
.env
.env.*
!.env.example

# Mastra runtime workspace (user uploads, generated Remotion code, renders)
mastra/.workspace/

# local databases — LibSQL / SQLite (memory + knowledge store)
mastra/data/
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite-journal

# build / bundle output
out/
dist/
build/
.mastra/
*.tgz

# caches
.cache/
.vite/
.turbo/
.eslintcache
*.tsbuildinfo

# logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# coverage
coverage/
*.lcov

# editors / IDEs
.idea/
.vscode/
*.swp
*.swo

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Claude / agent local config
.claude/
public/
